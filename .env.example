# Demo configuration only. Do not put real secrets here.

APP_ENV=demo
APP_NAME=2gis-category-lead-parser

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lead_parser_demo_db
POSTGRES_USER=demo_user
POSTGRES_PASSWORD=CHANGE_ME_LOCALLY

DGIS_API_KEY=DEMO_DGIS_API_KEY
DGIS_DEFAULT_CITY=Москва
DGIS_DEFAULT_LIMIT=30

ENRICHMENT_ENABLED=true
EXPORT_CSV=true
EXPORT_PATH=exports/leads_demo.csv

REQUEST_TIMEOUT_SECONDS=15
REQUEST_DELAY_SECONDS=1
